---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Card from "../../components/ui/Card.astro";

const lang = "en";
const path = "/about";
---

<BaseLayout title="About | Bridge Builders" lang={lang}>
  <Header lang={lang} path={path} />

  <main class="mx-auto max-w-5xl p-6">
    <h1 class="text-3xl font-semibold tracking-tight">About</h1>
    <p class="mt-3 text-[rgb(var(--muted))]">
      Bridge Builders supports Third Culture Kids (TCKs) through community, training, and resources.
    </p>

    <div class="mt-6 grid gap-4 md:grid-cols-2">
      <Card>
        <h2 class="text-lg font-semibold">What we do</h2>
        <p class="mt-2 text-sm text-[rgb(var(--muted))]">
          Workshops, seminars, and resources for families, schools, and organizations.
        </p>
      </Card>

      <Card>
        <h2 class="text-lg font-semibold">Who it’s for</h2>
        <p class="mt-2 text-sm text-[rgb(var(--muted))]">TCKs, parents, educators, and community leaders.</p>
      </Card>
    </div>
  </main>

  <Footer lang={lang} />
</BaseLayout>
