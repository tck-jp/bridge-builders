---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Card from "../../components/ui/Card.astro";
import Button from "../../components/ui/Button.astro";
import { resources } from "../../content/resources.en";

const lang = "en";
const path = "/resources";
---

<BaseLayout title="Resources | Bridge Builders" lang={lang}>
  <Header lang={lang} path={path} />

  <main class="mx-auto max-w-5xl p-6">
    <h1 class="text-3xl font-semibold tracking-tight">Resources</h1>
    <p class="mt-3 text-[rgb(var(--muted))]">Training and seminars you can sign up for.</p>

    <div class="mt-6 grid gap-4 md:grid-cols-2">
      {
        resources.map((r) => (
          <Card>
            <h2 class="text-lg font-semibold">{r.title}</h2>
            <p class="mt-2 text-sm text-[rgb(var(--muted))]">{r.description}</p>
            <div class="mt-4">
              <Button href={r.href} variant="primary">
                {r.cta}
              </Button>
            </div>
          </Card>
        ))
      }
    </div>
  </main>

  <Footer lang={lang} />
</BaseLayout>
