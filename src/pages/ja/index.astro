---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Button from "../../components/ui/Button.astro";
import Card from "../../components/ui/Card.astro";

const lang = "ja";
---

<BaseLayout
  title="Bridge Builders | ホーム"
  lang={lang}
  description="Bridge Buildersは、サードカルチャーキッズ（TCK）を支えるNPOです。コミュニティ、研修、リソースを提供します。"
>
  <header class="border-b border-[rgb(var(--border))] bg-[rgb(var(--bg))]">
    <div class="mx-auto flex max-w-5xl items-center justify-between p-4">
      <a href="/ja/" class="font-semibold tracking-tight">Bridge Builders</a>

      <nav class="hidden items-center gap-5 text-sm md:flex">
        <a class="hover:underline" href="/ja/about">私たちについて</a>
        <a class="hover:underline" href="/ja/resources">リソース</a>
        <a class="hover:underline" href="/ja/contact">お問い合わせ</a>
      </nav>

      <div class="flex items-center gap-2">
        <a
          href="/en/"
          class="rounded-md border border-[rgb(var(--border))] bg-[rgb(var(--surface))] px-3 py-2 text-sm hover:bg-[rgb(var(--surface-2))]"
        >
          English
        </a>
        <button
          type="button"
          onclick="window.__toggleTheme()"
          class="rounded-md border border-[rgb(var(--border))] bg-[rgb(var(--surface))] px-3 py-2 text-sm hover:bg-[rgb(var(--surface-2))]"
          aria-label="テーマ切替"
        >
          🌓
        </button>
      </div>
    </div>
  </header>

  <main class="mx-auto max-w-5xl p-6">
    <!-- ヒーロー -->
    <section class="py-10 md:py-14">
      <p class="text-sm font-medium text-[rgb(var(--muted))]">NPO • サードカルチャーキッズ</p>

      <h1 class="mt-3 text-4xl font-semibold tracking-tight md:text-5xl">異文化の間で育つTCKの「居場所」を支える。</h1>

      <p class="mt-4 max-w-2xl text-base text-[rgb(var(--muted))]">
        Bridge Buildersは、サードカルチャーキッズ（TCK）と、その周囲の大人（保護者・教育関係者・組織）を対象に、
        実践的なリソース、研修、コミュニティを提供します。
      </p>

      <div class="mt-6 flex flex-wrap gap-3">
        <Button href="/ja/resources" variant="primary">リソースを見る</Button>
        <Button href="/ja/contact" variant="secondary">問い合わせる</Button>
      </div>

      <div class="mt-8 grid gap-4 md:grid-cols-3">
        <Card>
          <h2 class="text-base font-semibold">リソース</h2>
          <p class="mt-2 text-sm text-[rgb(var(--muted))]">
            TCK・家族・教育関係者向けのガイドや記事、リンク集。
          </p>
        </Card>

        <Card>
          <h2 class="text-base font-semibold">研修</h2>
          <p class="mt-2 text-sm text-[rgb(var(--muted))]">
            学校・コミュニティ・組織向けのセミナーやワークショップ。
          </p>
        </Card>

        <Card>
          <h2 class="text-base font-semibold">コミュニティ</h2>
          <p class="mt-2 text-sm text-[rgb(var(--muted))]">
            つながり、語り合い、健やかなアイデンティティを育む場。
          </p>
        </Card>
      </div>
    </section>

    <!-- 私たちの活動 -->
    <section class="border-t border-[rgb(var(--border))] py-10">
      <h2 class="text-2xl font-semibold tracking-tight">私たちの活動</h2>

      <div class="mt-6 grid gap-4 md:grid-cols-2">
        <Card>
          <h3 class="text-lg font-semibold">セミナー／ワークショップ</h3>
          <p class="mt-2 text-sm text-[rgb(var(--muted))]">
            大人がTCKを支えるための、実践的で根拠に基づく内容を提供します。
          </p>
          <div class="mt-4">
            <Button href="/ja/resources" variant="ghost">開催予定を見る →</Button>
          </div>
        </Card>

        <Card>
          <h3 class="text-lg font-semibold">連携・協働</h3>
          <p class="mt-2 text-sm text-[rgb(var(--muted))]">
            学校や組織と連携し、継続可能な支援の仕組みづくりを行います。
          </p>
          <div class="mt-4">
            <Button href="/ja/contact" variant="ghost">連携の相談 →</Button>
          </div>
        </Card>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-10">
      <div class="rounded-2xl border border-[rgb(var(--border))] bg-[rgb(var(--surface))] p-6 shadow-[var(--shadow)]">
        <h2 class="text-2xl font-semibold tracking-tight">研修・セミナーに参加する</h2>
        <p class="mt-2 max-w-2xl text-sm text-[rgb(var(--muted))]">
          開催予定から申込みできます。学校・組織向けに研修をご希望の場合は、お問い合わせください。
        </p>
        <div class="mt-5 flex flex-wrap gap-3">
          <Button href="/ja/resources" variant="primary">リソース一覧</Button>
          <Button href="/ja/contact" variant="secondary">研修を相談する</Button>
        </div>
      </div>
    </section>
  </main>

  <footer class="border-t border-[rgb(var(--border))]">
    <div class="mx-auto max-w-5xl p-6 text-sm text-[rgb(var(--muted))]">© Bridge Builders</div>
  </footer>
</BaseLayout>
