

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Button from "../../components/ui/Button.astro";

const lang = "ja";
const path = "/contact";
---

<BaseLayout lang={lang}>
  <Header lang={lang} path={path} />

  <main class="mx-auto max-w-5xl p-6">
    <h1 class="text-3xl font-semibold tracking-tight">お問い合わせ</h1>
    <p class="mt-3 text-[rgb(var(--muted))]">
      Bridge Builders へのご質問、活動への参加、研修・セミナーのご相談など、
      お気軽にご連絡ください。
    </p>

    <form class="mt-8 max-w-xl space-y-4" method="post">
      <div>
        <label for="name" class="text-sm font-medium">お名前</label>
        <input
          id="name"
          name="name"
          type="text"
          autocomplete="name"
          class="mt-2 w-full rounded-md border border-[rgb(var(--border))] bg-[rgb(var(--surface))] px-3 py-2 text-[rgb(var(--fg))] placeholder:text-[rgb(var(--muted))] focus:outline-none focus-visible:ring-2 focus-visible:ring-[rgb(var(--focus))] focus-visible:ring-offset-2 focus-visible:ring-offset-[rgb(var(--bg))]"
          placeholder="例：山田 太郎"
        />
      </div>

      <div>
        <label for="email" class="text-sm font-medium">メールアドレス</label>
        <input
          id="email"
          name="email"
          type="email"
          autocomplete="email"
          class="mt-2 w-full rounded-md border border-[rgb(var(--border))] bg-[rgb(var(--surface))] px-3 py-2 text-[rgb(var(--fg))] placeholder:text-[rgb(var(--muted))] focus:outline-none focus-visible:ring-2 focus-visible:ring-[rgb(var(--focus))] focus-visible:ring-offset-2 focus-visible:ring-offset-[rgb(var(--bg))]"
          placeholder="example@domain.com"
        />
      </div>

      <div>
        <label for="message" class="text-sm font-medium">内容</label>
        <textarea
          id="message"
          name="message"
          rows={5}
          class="mt-2 w-full rounded-md border border-[rgb(var(--border))] bg-[rgb(var(--surface))] px-3 py-2 text-[rgb(var(--fg))] placeholder:text-[rgb(var(--muted))] focus:outline-none focus-visible:ring-2 focus-visible:ring-[rgb(var(--focus))] focus-visible:ring-offset-2 focus-visible:ring-offset-[rgb(var(--bg))]"
          placeholder="ご相談内容をご記入ください。"
        ></textarea>
      </div>

      <div class="pt-2">
        <Button type="submit">送信</Button>
      </div>

      <p class="text-xs text-[rgb(var(--muted))]">
        ※現在このフォームはデモです。送信先の設定は後ほど追加します。
      </p>
    </form>
  </main>

  <Footer />
</BaseLayout>