---
/**
 * Card.astro
 * Token-based surface component.
 */
const { class: className = "" } = Astro.props;

const classes = [
  "rounded-[var(--radius)]",
  "border",
  "border-[rgb(var(--border))]",
  "bg-[rgb(var(--surface))]",
  "text-[rgb(var(--fg))]",
  "p-6",
  "shadow-[var(--shadow)]",
  "transition-colors",
  className,
]
  .filter(Boolean)
  .join(" ");
---

<div class={classes}>
  <slot />
</div>
