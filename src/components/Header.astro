---
import ThemeToggle from "./ThemeToggle.astro";
import LanguageToggle from "./LanguageToggle.astro";

const { lang = "en", path = "/" } = Astro.props;

const t =
  lang === "en"
    ? { home: "Home", about: "About", resources: "Resources", contact: "Contact" }
    : { home: "ホーム", about: "私たちについて", resources: "リソース", contact: "お問い合わせ" };

const base = `/${lang}`;
---
<header class="border-b border-[rgb(var(--border))] bg-[rgb(var(--bg))] text-[rgb(var(--fg))]">
  <div class="mx-auto flex max-w-5xl items-center justify-between p-4">
    <a href={`${base}/`} class="inline-flex items-center" aria-label="Bridge Builders">
      <img
        src="/logo/bridge-builders-logo.svg"
        alt="Bridge Builders"
        width="64"
        height="32"
        class="h-8 w-auto"
        loading="eager"
        decoding="async"
      />
    </a>

    <nav class="hidden items-center gap-5 text-sm md:flex">
      <a
        class="text-[rgb(var(--fg))] hover:text-[rgb(var(--muted))] transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-[rgb(var(--focus))] focus-visible:ring-offset-2 focus-visible:ring-offset-[rgb(var(--bg))]"
        href={`${base}/`}
      >
        {t.home}
      </a>
      <a
        class="text-[rgb(var(--fg))] hover:text-[rgb(var(--muted))] transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-[rgb(var(--focus))] focus-visible:ring-offset-2 focus-visible:ring-offset-[rgb(var(--bg))]"
        href={`${base}/about`}
      >
        {t.about}
      </a>
      <a
        class="text-[rgb(var(--fg))] hover:text-[rgb(var(--muted))] transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-[rgb(var(--focus))] focus-visible:ring-offset-2 focus-visible:ring-offset-[rgb(var(--bg))]"
        href={`${base}/resources`}
      >
        {t.resources}
      </a>
      <a
        class="text-[rgb(var(--fg))] hover:text-[rgb(var(--muted))] transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-[rgb(var(--focus))] focus-visible:ring-offset-2 focus-visible:ring-offset-[rgb(var(--bg))]"
        href={`${base}/contact`}
      >
        {t.contact}
      </a>
    </nav>

    <div class="flex items-center gap-2">
      <LanguageToggle lang={lang} path={path} />
      <ThemeToggle label={lang === "en" ? "Toggle theme" : "テーマ切替"} />
    </div>
  </div>
</header>
