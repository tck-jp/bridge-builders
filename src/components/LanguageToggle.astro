---
const { lang = "en", path = "/", class: className = "" } = Astro.props;

const otherLang = lang === "en" ? "ja" : "en";
const otherLabel = lang === "en" ? "日本語" : "English";
const otherHref = `/${otherLang}${path === "/" ? "/" : path}`;

const classes = [
  "rounded-md",
  "border",
  "border-[rgb(var(--border))]",
  "bg-[rgb(var(--bg))]",
  "text-[rgb(var(--fg))]",
  "px-3",
  "py-2",
  "text-sm",
  "transition-colors",
  "hover:bg-[rgb(var(--surface-2))]",
  "focus:outline-none",
  "focus-visible:ring-2",
  "focus-visible:ring-[rgb(var(--focus))]",
  "focus-visible:ring-offset-2",
  "focus-visible:ring-offset-[rgb(var(--bg))]",
  className,
]
  .filter(Boolean)
  .join(" ");
---

<a href={otherHref} class={classes}>
  {otherLabel}
</a>
