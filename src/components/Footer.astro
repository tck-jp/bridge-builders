---
const { lang = "en" } = Astro.props;
const text = lang === "en" ? "© Bridge Builders" : "© Bridge Builders";
---

<footer class="border-t border-[rgb(var(--border))] bg-[rgb(var(--surface))]">
  <div class="mx-auto max-w-5xl p-6 text-sm text-[rgb(var(--muted))] transition-colors">
    {text}
  </div>
</footer>
